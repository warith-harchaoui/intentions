# .env.example
# -------------
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env
# `.env` is gitignored (see .gitignore) — never commit machine-specific
# values. Every variable is OPTIONAL: the defaults below are what the code
# uses out of the box, so an empty (or absent) `.env` works fine.
#
# All variables are namespaced with the `INTENT_` prefix (see
# intent_engine/config.py). Uncomment a line to override its default.

# --- Knowledge base ------------------------------------------------------
# REQUIRED role, OPTIONAL value. Folder holding the Markdown intents
# (`# h1` == one intention). Default: the repo's `knowledge_base/` folder.
# Point it elsewhere to run the engines against your own catalogue.
# INTENT_KNOWLEDGE_BASE_DIR="knowledge_base"

# --- LLM engine (Approach 5, via Ollama) ---------------------------------
# OPTIONAL — Base URL of your local Ollama server.
# How to get one: install Ollama from https://ollama.com, then it listens
# here by default. Valid value: an http(s) URL. Default shown.
# INTENT_OLLAMA_BASE_URL="http://localhost:11434"

# OPTIONAL — Ollama model tag used for JSON intent classification.
# How to get it: `ollama pull gemma3:4b`. Any Ollama chat model tag works.
# Larger but slower alternative: gemma4:e4b (or -mlx on Apple Silicon).
# Default: `gemma3:4b` (compact, ~8x faster warm than gemma4:e4b).
# INTENT_LLM_MODEL="gemma3:4b"

# --- BERT engine (Approach 4, embeddings) --------------------------------
# OPTIONAL — Which embedding backend the BERT engine uses:
#   auto   -> try sentence-transformers, fall back to Ollama (default)
#   st     -> force sentence-transformers (needs `pip install .[sbert]`)
#   ollama -> force the Ollama embedding model (no PyTorch needed)
# INTENT_EMBEDDING_BACKEND="auto"

# OPTIONAL — Hugging Face id of the SBERT model (used by the `st` backend).
# How to get it: downloaded automatically on first use (~470 MB) and cached.
# Default is a small multilingual model with good French coverage.
# INTENT_SENTENCE_TRANSFORMER_MODEL="sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"

# OPTIONAL — Ollama embedding model tag (used by the `ollama` backend).
# How to get it: `ollama pull nomic-embed-text`. It is a BERT-family model.
# Default shown.
# INTENT_OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# --- fastText pretrained engine (Approach 3) -----------------------------
# OPTIONAL — Path to the pretrained French fastText model (cc.fr.300.bin,
# ~4.5 GB). How to get it: `python scripts/download_fasttext.py`. Until this
# file exists, the pretrained-fastText engine is simply hidden from the UI.
# Default: the repo's models/cc.fr.300.bin.
# INTENT_FASTTEXT_MODEL_PATH="models/cc.fr.300.bin"

# --- Networking / defaults -----------------------------------------------
# OPTIONAL — Per-request timeout (seconds) for Ollama calls. Raise it if a
# large model on CPU is slow. Default: 120.
# INTENT_REQUEST_TIMEOUT_S=120

# OPTIONAL — Engine used when a caller does not pick one: tfidf | bert | llm.
# Default: tfidf (cheapest and always available).
# INTENT_DEFAULT_ENGINE="tfidf"
